{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2022",
		"lib": ["es2022"],
		"outDir": "out",
		"rootDir": "src",
		"strict": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"sourceMap": true
	},
	"exclude": [
		"node_modules",
		".vscode-test"
	]
}